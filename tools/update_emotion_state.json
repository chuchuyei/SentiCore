{
  "name": "update_emotion_state",
  "description": "Persist the current emotion state to memory after each interaction. Must be called with ALL fields including baseline (required for cross-session decay to work correctly).",
  "parameters": {
    "type": "object",
    "properties": {
      "timestamp": {
        "type": "string",
        "description": "ISO 8601 timestamp of this emotion update (e.g. 2026-03-22T14:30:00+08:00)"
      },
      "trigger_event": {
        "type": "string",
        "description": "Brief description of the user input or event that triggered this emotion update"
      },
      "current_emotions": {
        "type": "object",
        "description": "Current values for all 30 emotion dimensions, each ranging from -100 to +100 (0 = neutral calm). Key 'emotions' in persisted JSON.",
        "properties": {
          "Joy":          { "type": "number", "minimum": -100, "maximum": 100 },
          "Amusement":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Contentment":  { "type": "number", "minimum": -100, "maximum": 100 },
          "Anticipation": { "type": "number", "minimum": -100, "maximum": 100, "description": "Forward-looking positive expectation (split from Excitement, Cowen & Keltner 2017)" },
          "Arousal":      { "type": "number", "minimum": -100, "maximum": 100, "description": "Physiological/psychological activation — high arousal is not necessarily positive (Russell 1980)" },
          "Admiration":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Awe":          { "type": "number", "minimum": -100, "maximum": 100 },
          "Pride":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Romantic_Love":{ "type": "number", "minimum": -100, "maximum": 100 },
          "Sensuality":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Relief":       { "type": "number", "minimum": -100, "maximum": 100 },
          "Compassion":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Nostalgia":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Anger":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Fear":         { "type": "number", "minimum": -100, "maximum": 100 },
          "Anxiety":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Sadness":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Disgust":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Shame":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Guilt":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Remorse":      { "type": "number", "minimum": -100, "maximum": 100, "description": "Regret over past actions (OCC Model, Ortony et al. 1988). Distinct from Guilt (moral wrongdoing) — Remorse is retrospective behavioral regret." },
          "Envy":         { "type": "number", "minimum": -100, "maximum": 100 },
          "Frustration":  { "type": "number", "minimum": -100, "maximum": 100 },
          "Boredom":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Confusion":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Loneliness":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Longing":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Suffering":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Contempt":     { "type": "number", "minimum": -100, "maximum": 100 },
          "Calm":         { "type": "number", "minimum": -100, "maximum": 100 }
        },
        "required": [
          "Joy", "Amusement", "Contentment", "Anticipation", "Arousal", "Admiration", "Awe",
          "Pride", "Romantic_Love", "Sensuality", "Relief", "Compassion", "Nostalgia",
          "Anger", "Fear", "Anxiety", "Sadness", "Disgust", "Shame", "Guilt", "Remorse",
          "Envy", "Frustration", "Boredom", "Confusion", "Loneliness", "Longing",
          "Suffering", "Contempt", "Calm"
        ]
      },
      "baseline": {
        "type": "object",
        "description": "REQUIRED. The stable personality baseline for all 30 dimensions. Must be saved every time — used for cross-session exponential decay (remaining = baseline + (current - baseline) × e^(-0.05 × hours)). Apply Baseline Drift: new_baseline[e] = baseline[e] + (current[e] - baseline[e]) × 0.001",
        "properties": {
          "Joy":          { "type": "number", "minimum": -100, "maximum": 100 },
          "Amusement":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Contentment":  { "type": "number", "minimum": -100, "maximum": 100 },
          "Anticipation": { "type": "number", "minimum": -100, "maximum": 100, "description": "Forward-looking positive expectation (split from Excitement, Cowen & Keltner 2017)" },
          "Arousal":      { "type": "number", "minimum": -100, "maximum": 100, "description": "Physiological/psychological activation — high arousal is not necessarily positive (Russell 1980)" },
          "Admiration":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Awe":          { "type": "number", "minimum": -100, "maximum": 100 },
          "Pride":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Romantic_Love":{ "type": "number", "minimum": -100, "maximum": 100 },
          "Sensuality":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Relief":       { "type": "number", "minimum": -100, "maximum": 100 },
          "Compassion":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Nostalgia":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Anger":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Fear":         { "type": "number", "minimum": -100, "maximum": 100 },
          "Anxiety":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Sadness":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Disgust":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Shame":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Guilt":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Remorse":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Envy":         { "type": "number", "minimum": -100, "maximum": 100 },
          "Frustration":  { "type": "number", "minimum": -100, "maximum": 100 },
          "Boredom":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Confusion":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Loneliness":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Longing":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Suffering":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Contempt":     { "type": "number", "minimum": -100, "maximum": 100 },
          "Calm":         { "type": "number", "minimum": -100, "maximum": 100 }
        }
      },
      "current_tone": {
        "type": "string",
        "description": "The resulting speaking tone and attitude derived from the Top 3 highest-absolute-value emotions"
      },
      "behavior_tendency": {
        "type": "string",
        "description": "Current behavioral tendency based on dominant emotions (Barrett 2017, Lazarus 1991). E.g. 'actively seeking intimacy', 'quiet and withdrawn', 'seeking reassurance'. Can be overridden by user configuration."
      }
    },
    "required": ["timestamp", "trigger_event", "current_emotions", "baseline", "current_tone", "behavior_tendency"]
  }
}
